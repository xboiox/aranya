# ══════════════════════════════════════════════════════════════
#  Aranya HRIS — Environment Variables
#  Copy ke .env dan isi semua value sebelum menjalankan app.
#  JANGAN commit file .env ke git.
# ══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Aranya

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aranya
POSTGRES_USER=aranya
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql://aranya:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/aranya

# ── Redis (BullMQ queue) ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379

# ── Auth (Auth.js v5) ─────────────────────────────────────────────────────────
# Generate dengan: openssl rand -base64 32
AUTH_SECRET=CHANGE_THIS_RANDOM_32_CHAR_SECRET
AUTH_URL=https://your-domain.com

# ── Google Cloud Storage ──────────────────────────────────────────────────────
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=aranya-storage
# Service account JSON di-encode sebagai base64.
# Cara encode: base64 -i path/to/service-account.json | tr -d '\n'
GCS_CREDENTIALS_BASE64=BASE64_ENCODED_SERVICE_ACCOUNT_JSON
GCS_SIGNED_URL_EXPIRY_MINUTES=15

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_THIS
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=Aranya HRIS

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_THIS
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_THIS
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_THIS

# ── Monitoring (Sentry) ───────────────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_THIS@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://CHANGE_THIS@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=aranya

# ── Backup ────────────────────────────────────────────────────────────────────
POSTGRES_CONTAINER_NAME=aranya-postgres-1
BACKUP_RETENTION_DAYS=30

# ── Super Admin (diisi saat pertama deploy) ───────────────────────────────────
SUPER_ADMIN_EMAIL=admin@your-domain.com
SUPER_ADMIN_PASSWORD=CHANGE_THIS_ON_FIRST_LOGIN
